# Port the app is accessible on your host machine
APP_PORT=4000

# Path to music folder (bind-mounted into Docker)
# Windows:  MUSIC_DIR=C:/Users/yourname/Music
# Linux:    MUSIC_DIR=/home/yourname/music
MUSIC_DIR=./music

# ── Security (CHANGE THESE in production) ──────────────────────────────────

# Long random string used to sign JWT tokens.
# Generate one: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Admin account credentials (created automatically on first run).
# If ADMIN_PASSWORD is not set, a random one is printed in the backend logs.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Set to "true" when running behind HTTPS (enables Secure flag on cookies).
SECURE_COOKIE=false
