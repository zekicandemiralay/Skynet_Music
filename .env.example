# Port the app is accessible on your host machine
HTTP_PORT=8080
HTTPS_PORT=4000

# Your server's local network IP address (e.g. 192.168.1.100)
# Run: ip addr show  (Linux) or ipconfig (Windows) to find it
# This goes into the TLS certificate's Subject Alternative Name so phones accept it
SERVER_IP=192.168.1.x

# Path to music folder
# Windows: MUSIC_DIR=C:/Users/yourname/Music
# Linux:   MUSIC_DIR=/home/yourname/music
MUSIC_DIR=./music

# Long random string used to sign login tokens — never share this
JWT_SECRET=change-this-to-a-long-random-string

# Admin username (default: admin)
ADMIN_USERNAME=admin

# ADMIN_PASSWORD: intentionally left out.
# On first start, if this is not set, the backend auto-generates
# a random password and prints it ONCE in the logs:
#   docker compose logs backend
# After that, change it inside the app.

# Always true now — the app runs over HTTPS
SECURE_COOKIE=true

# Surfshark WireGuard private key for routing downloads through VPN
# Find it in: Surfshark dashboard → VPN → Manual Setup → WireGuard → generate config
# Copy the PrivateKey= line from the [Interface] section
WIREGUARD_PRIVATE_KEY=

# VPN server country for downloads (default: Netherlands)
# See gluetun docs for supported Surfshark country names
VPN_COUNTRY=Netherlands
